# Elasticsearch / Kibana (shared API key for both)
ES_URL=https://your-cluster.es.io:9200
ES_API_KEY=your_base64_encoded_api_key_here

# Kibana (optional — same API key, different port/URL)
KIBANA_URL=https://your-cluster.kb.io:5601

# LLM — any OpenAI-compatible /chat/completions endpoint
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Output directory for generated reports and CSVs
OUTPUT_DIR=./output

# Safety cap on agentic tool-call iterations
MAX_ITERATIONS=20

# Set to false for clusters with self-signed certificates
# ES_TLS_VERIFY=false

# Set to true to print full stack traces on errors
# DEBUG=true
